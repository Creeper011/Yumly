{
  "name": "yumly",
  "displayName": "Yumly",
  "description": "Syntax highlighting for Yumly language",
  "version": "0.0.1",
  "publisher": "yumene",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "yumly",
      "aliases": ["Yumly", "yumly"],
      "extensions": [".yumly",".yuy"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "yumly",
      "scopeName": "source.yumly",
      "path": "./syntaxes/yumly.tmLanguage.json"
    }]
  }
}
